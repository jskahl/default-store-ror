<% local_assigns[:value] %>
<% local_assigns[:form] %>
<% local_assigns[:label] %>

<div class="flex flex-col">
  <%= form.label value, label, class: 'text-xs px-1' %>
  <div class="w-52 h-8 px-1 flex items-center rounded-sm border-gray-400 border">
    <%= form.text_field value, class: 'w-full focus:outline-none' %>
  </div>
</div>
